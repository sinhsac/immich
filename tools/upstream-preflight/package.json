{
  "name": "@immich-fork/upstream-preflight",
  "version": "1.0.0",
  "description": "CLI tool to manage rebase/merge from upstream Immich",
  "type": "module",
  "bin": {
    "upstream-preflight": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "preflight": "tsx src/index.ts check",
    "merge-dry": "tsx src/index.ts merge --dry-run",
    "conflicts": "tsx src/index.ts conflicts"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
